---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — Page Not Found | FastClickTest.com" description="The page you're looking for doesn't exist. Go back to FastClickTest.com to take a free click speed test.">
  <section style="text-align:center;padding:80px 20px;max-width:500px;margin:0 auto;">
    <div style="font-size:5rem;margin-bottom:16px;">🖱️</div>
    <h1 style="font-family:var(--font-display);font-size:2.5rem;color:var(--accent);margin-bottom:12px;">404</h1>
    <h2 style="font-size:1.3rem;margin-bottom:16px;">Page Not Found</h2>
    <p style="color:var(--muted);margin-bottom:32px;">This page doesn't exist. Maybe you clicked too fast and ended up somewhere weird?</p>
    <a href="/" class="btn btn-primary" style="display:inline-block;padding:14px 32px;">← Back to CPS Test</a>
  </section>
</Layout>
