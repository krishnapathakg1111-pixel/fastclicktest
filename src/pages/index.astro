<script>
const RATINGS = [
  {min:0,  max:2,  emoji:'🐢',label:'Turtle',      color:'#f87171',desc:"Keep going — practice makes perfect!"},
  {min:2,  max:4,  emoji:'🐌',label:'Slow',        color:'#fb923c',desc:"You're warming up — try again!"},
  {min:4,  max:6,  emoji:'✌️',label:'Average',     color:'#facc15',desc:"Solid! Most casual users score here."},
  {min:6,  max:8,  emoji:'⚡',label:'Fast',        color:'#4ade80',desc:"Quick! You're in the top 30%."},
  {min:8,  max:10, emoji:'🔥',label:'Insane',      color:'#60a5fa',desc:"Impressive — top 10% of all players."},
  {min:10, max:14, emoji:'🚀',label:'Godlike',     color:'#c084fc',desc:"Elite level — top 2% worldwide."},
  {min:14, max:999,emoji:'👑',label:'World Class', color:'#fbbf24',desc:"Legendary — world record territory!"},
];
const getRating = cps => RATINGS.find(r => cps >= r.min && cps < r.max) ?? RATINGS.at(-1);

const KEY = 'fct_scores_v1';
let clicks=0, running=false, mode='time', limit=5, t0=null, elapsed=0, ticker=null, hist=[];
let scores=[], best=0;

const $=id=>document.getElementById(id);
const area=$('click-area'), statCPS=$('stat-cps'), statTimer=$('stat-timer'),
      statTimerLbl=$('stat-timer-lbl'), statBest=$('stat-best'),
      caNum=$('ca-num'), caIdle=$('ca-idle'), caRunning=$('ca-running'),
      statusTxt=$('status-text'), histList=$('history-list'), overlay=$('result-overlay');

// Canvas
const canvas=$('click-graph'); let ctx=null;
function initCanvas(){
  if(!canvas)return;
  const dpr=window.devicePixelRatio||1, w=canvas.parentElement.clientWidth-32;
  canvas.width=w*dpr; canvas.height=60*dpr;
  canvas.style.width=w+'px'; canvas.style.height='60px';
  ctx=canvas.getContext('2d'); ctx.scale(dpr,dpr);
}
initCanvas(); window.addEventListener('resize',initCanvas);

function drawGraph(){
  if(!ctx||hist.length<2)return;
  const W=canvas.offsetWidth,H=canvas.offsetHeight;
  ctx.clearRect(0,0,W,H);
  const maxCPS=Math.max(...hist.map(p=>p.c),6);
  const maxT=mode==='time'?limit:Math.max(elapsed,0.1);
  ctx.strokeStyle='rgba(255,255,255,0.04)'; ctx.lineWidth=1;
  [0.25,0.5,0.75].forEach(f=>{ctx.beginPath();ctx.moveTo(0,H*f);ctx.lineTo(W,H*f);ctx.stroke();});
  const pts=hist.map(p=>({x:(p.t/maxT)*W,y:H-(p.c/maxCPS)*H*0.88}));
  // glow pass
  ctx.beginPath(); ctx.lineWidth=6; ctx.strokeStyle='rgba(0,229,255,0.15)';
  ctx.lineJoin='round'; ctx.lineCap='round';
  pts.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y)); ctx.stroke();
  // main line
  ctx.beginPath(); ctx.lineWidth=2; ctx.strokeStyle='#00e5ff';
  pts.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y)); ctx.stroke();
  // fill
  ctx.lineTo(pts.at(-1).x,H); ctx.lineTo(0,H);
  ctx.closePath(); ctx.fillStyle='rgba(0,229,255,0.06)'; ctx.fill();
}
function clearGraph(){if(ctx)ctx.clearRect(0,0,canvas.offsetWidth,canvas.offsetHeight);}

// Scores
function loadScores(){
  try{scores=JSON.parse(localStorage.getItem(KEY)||'[]');}catch{scores=[];}
  best=scores.length?Math.max(...scores.map(s=>s.cps)):0;
}
function saveScore(cps,cl,el){
  scores.unshift({cps:+cps.toFixed(2),clicks:cl,time:+el.toFixed(2),
    mode:mode==='time'?limit+'s':'100 clicks',date:new Date().toLocaleDateString()});
  scores=scores.slice(0,20);
  localStorage.setItem(KEY,JSON.stringify(scores));
  if(cps>best)best=cps;
}
function renderHistory(){
  if(!histList)return;
  if(!scores.length){histList.innerHTML='<p class="history-empty">No scores yet — take your first test!</p>';return;}
  histList.innerHTML=scores.slice(0,8).map((s,i)=>`
    <div class="history-row">
      <span class="history-rank">#${i+1}</span>
      <span class="history-cps">${s.cps} CPS</span>
      <span class="history-meta">${s.clicks} clicks · ${s.mode} · ${s.date}</span>
    </div>`).join('');
}
function updateBest(){if(statBest)statBest.textContent=best>0?best.toFixed(2):'--';}

// Click
function handleClick(e){
  if(!running)startTest();
  clicks++;
  if(caNum){
    caNum.textContent=clicks;
    caNum.classList.remove('bump');
    void caNum.offsetWidth;
    caNum.classList.add('bump');
  }
  // flash CPS stat
  const card=document.getElementById('stat-cps-card');
  if(card){card.classList.add('lit');setTimeout(()=>card.classList.remove('lit'),150);}
  ripple(e);
  if(mode==='count'&&clicks>=100)endTest();
}

function ripple(e){
  const rect=area.getBoundingClientRect();
  const x=(e?.clientX??e?.changedTouches?.[0]?.clientX??rect.left+rect.width/2)-rect.left;
  const y=(e?.clientY??e?.changedTouches?.[0]?.clientY??rect.top+rect.height/2)-rect.top;
  const r=document.createElement('div');
  r.className='ripple'; r.style.cssText=`left:${x}px;top:${y}px`;
  area.appendChild(r); setTimeout(()=>r.remove(),600);
}

function startTest(){
  running=true; t0=Date.now(); clicks=0; hist=[];
  area.classList.replace('idle','running');
  caIdle?.classList.add('hide'); caRunning?.classList.add('show');
  if(statusTxt)statusTxt.textContent='GO! Click as fast as you can!';
  clearGraph();
  ticker=setInterval(()=>{
    elapsed=(Date.now()-t0)/1000;
    const cps=elapsed>0?clicks/elapsed:0;
    if(statCPS)statCPS.textContent=cps.toFixed(2);
    if(mode==='time'){
      const rem=Math.max(0,limit-elapsed);
      if(statTimer)statTimer.textContent=rem.toFixed(1);
      if(elapsed>=limit){endTest();return;}
    } else {
      if(statTimer)statTimer.textContent=elapsed.toFixed(1)+'s';
    }
    hist.push({t:elapsed,c:cps}); drawGraph();
  },50);
}

function endTest(){
  clearInterval(ticker); running=false;
  area.classList.replace('running','idle');
  caIdle?.classList.remove('hide'); caRunning?.classList.remove('show');
  const el=elapsed||0.01, cps=clicks/el, rating=getRating(cps), isNew=cps>best;
  saveScore(cps,clicks,el); renderHistory(); updateBest();
  $('res-cps').textContent=cps.toFixed(2);
  $('res-clicks').textContent=clicks;
  $('res-time').textContent=el.toFixed(2)+'s';
  $('res-best').textContent=best.toFixed(2);
  const rEl=$('res-rating');
  rEl.textContent=rating.emoji+' '+rating.label; rEl.style.color=rating.color;
  $('res-desc').textContent=rating.desc;
  const nb=$('new-best'); if(nb)nb.style.display=isNew?'inline-block':'none';
  overlay?.classList.add('show');
}

function reset(){
  clearInterval(ticker); running=false; clicks=0; hist=[]; elapsed=0;
  area.classList.replace('running','idle');
  caIdle?.classList.remove('hide'); caRunning?.classList.remove('show');
  if(caNum)caNum.textContent='0';
  if(statCPS)statCPS.textContent='0.00';
  if(mode==='time'){
    if(statTimer)statTimer.textContent=limit.toFixed(1);
    if(statTimerLbl)statTimerLbl.textContent='Seconds';
  } else {
    if(statTimer)statTimer.textContent='0.0s';
    if(statTimerLbl)statTimerLbl.textContent='Time';
  }
  if(statusTxt)statusTxt.textContent='Select a mode above — timer starts on your first click';
  clearGraph(); updateBest();
}

document.querySelectorAll('.mode-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    if(running)return;
    document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    mode=btn.dataset.type==='count'?'count':'time';
    if(mode==='time')limit=+btn.dataset.mode;
    reset();
  });
});

area?.addEventListener('click',handleClick);
area?.addEventListener('touchstart',e=>{e.preventDefault();handleClick(e);},{passive:false});
area?.addEventListener('contextmenu',e=>e.preventDefault());

$('btn-again')?.addEventListener('click',()=>{overlay?.classList.remove('show');reset();});
$('btn-share')?.addEventListener('click',()=>{
  const cps=$('res-cps')?.textContent, rtg=$('res-rating')?.textContent;
  const txt=`I scored ${cps} CPS (${rtg}) on FastClickTest.com — can you beat me? 🖱️`;
  navigator.share?navigator.share({title:'My CPS Score',text:txt,url:location.href})
    :navigator.clipboard.writeText(txt).then(()=>{
      const b=$('btn-share');if(b){b.textContent='✅ Copied!';setTimeout(()=>b.textContent='Share 📤',2000);}
    });
});
overlay?.addEventListener('click',e=>{if(e.target===overlay){overlay.classList.remove('show');reset();}});
document.querySelectorAll('.faq-item').forEach(item=>{
  item.querySelector('.faq-q')?.addEventListener('click',()=>item.classList.toggle('open'));
});

loadScores(); updateBest(); renderHistory();
</script>
