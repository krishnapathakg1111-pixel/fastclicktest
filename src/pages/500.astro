---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="500 — Server Error | FastClickTest.com"
  description="Something went wrong on our end. Go back to FastClickTest.com to take a free click speed test."
>
<div class="page">
  <section style="text-align:center;padding:80px 20px;max-width:500px;margin:0 auto;">
    <div style="font-size:4rem;margin-bottom:16px;">⚠️</div>
    <h1 style="font-family:var(--font-game);font-size:2.5rem;color:var(--pink);margin-bottom:12px;letter-spacing:0.06em;">500</h1>
    <h2 style="font-size:1.2rem;margin-bottom:16px;font-family:var(--font-game);">Server Error</h2>
    <p style="color:var(--text-2);margin-bottom:32px;font-size:0.9rem;line-height:1.7;">
      Something went wrong on our end. It's not your fault — we're on it.
      Try refreshing the page, or go back to the homepage and take a click speed test while you wait.
    </p>
    <a href="/" class="btn btn-primary" style="display:inline-block;padding:14px 32px;text-decoration:none;">
      ← Back to CPS Test
    </a>
  </section>
</div>
</Layout>
